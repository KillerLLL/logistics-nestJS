# ============================================================
# .env.example — 环境变量模板
# 复制为 .env 后填入实际值；.env 自身不入库
# 生产环境请通过密钥管理（K8s Secret / Vault）注入真实值
# ============================================================

NODE_ENV=development
PORT=3000
GLOBAL_PREFIX=logistics-boot

# ---------- 数据库（替换原硬编码 root/525619） ----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=525619
DB_NAME=logistics
# 生产环境必须 false，由 migration 接管
DB_SYNCHRONIZE=false

# ---------- JWT ----------
# 至少 32 位随机串；示例仅占位，部署前必须重新生成
JWT_ACCESS_SECRET=__change_me_access_secret_min_32_chars__
JWT_ACCESS_TTL=2h
JWT_REFRESH_SECRET=__change_me_refresh_secret_min_32_chars__
JWT_REFRESH_TTL=14d

# ---------- 微信小程序 ----------
# AppID 来自前端 manifest.json
WX_MP_APPID=wx0e6298064ecefd68
# AppSecret 必须从微信公众平台后台申请，**先用占位符**，联调前替换为真实值
WX_MP_SECRET=__set_real_secret_from_weixin_mp_console__
# getPhoneNumber AES 解密密钥（base64，可选）
WX_MP_AES_KEY=

# ---------- 短信 / 风控（本期未启用，留位） ----------
SMS_PROVIDER=none
SMS_RATE_LIMIT_PER_MIN=5
LOGIN_FAIL_LOCK_THRESHOLD=5
LOGIN_FAIL_LOCK_MINUTES=15

# ---------- 对象存储（京东云 OSS / S3 兼容协议） ----------
# endpoint 固定 https://s3.cn-east-2.jdcloud-oss.com（华东-宿迁）
OSS_ENDPOINT=https://s3.cn-east-2.jdcloud-oss.com
OSS_REGION=cn-east-2
OSS_BUCKET=lin-nest
# publicHost = https://{bucket}.s3.cn-east-2.jdcloud-oss.com（bucket 需控制台开「公有读」）
OSS_PUBLIC_HOST=https://lin-nest.s3.cn-east-2.jdcloud-oss.com
# bucket 内目录前缀
OSS_PATH_PREFIX=ul-nestJS/
# 控制台 → 访问控制 → AccessKey 管理
OSS_ACCESS_KEY_ID=__set_real_ak__
OSS_SECRET_ACCESS_KEY=__set_real_sk__
# 单文件上限 10MB
OSS_MAX_SIZE=10485760

# ---------- 腾讯云 OCR（文字识别） ----------
# 未配置或以 __ 开头时自动启用 mock 模式
OCR_TENCENT_SECRET_ID=
OCR_TENCENT_SECRET_KEY=
